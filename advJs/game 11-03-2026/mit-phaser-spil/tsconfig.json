{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@scenes/*": ["src/scenes/*"],
      "@objects/*": ["src/objects/*"],
      "@config/*": ["src/config/*"]
    }
  },
  "include": ["src"]
}